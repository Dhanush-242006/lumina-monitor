# ── Required ──────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Optional: AI features ─────────────────────────────────────────────────────
# Get from: aistudio.google.com
GEMINI_API_KEY=

# Get from: console.groq.com/keys
GROQ_API_KEY=

# ── Optional: Supabase integration ────────────────────────────────────────────
# Get from: supabase.com → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=

# Found in your Supabase project URL: https://<ref>.supabase.co
SUPABASE_PROJECT_REF=

# Get from: Supabase project → Settings → API → anon/public key
SUPABASE_ANON_KEY=
